name: axm-quality

on:
  push:
    branches: [main]

permissions:
  contents: write

jobs:
  quality:
    name: AXM Audit + Init + Badges
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
        with:
          fetch-depth: 0
      - uses: astral-sh/setup-uv@v7
      - run: uv python install 3.12
      - run: uv sync --all-groups

      # ── Badge helpers ──────────────────────────────────────────────
      - name: Define badge helpers
        id: helpers
        run: |
          cat > /tmp/badge-helpers.sh << 'HELPERS'
          score_color() {
            local SCORE=$1
            if [ "$SCORE" -ge 95 ]; then echo "brightgreen"
            elif [ "$SCORE" -ge 80 ]; then echo "green"
            elif [ "$SCORE" -ge 60 ]; then echo "yellow"
            else echo "red"; fi
          }

          write_badge() {
            local DIR=$1 NAME=$2 LABEL=$3 VALUE=$4 LOGO_FILE=${5:-}
            mkdir -p "$DIR"
            local SCORE_INT=$(python3 -c "print(int(float('${VALUE}')))")
            local COLOR=$(score_color "$SCORE_INT")
            # Inline the logo only when the SVG was fetched and is non-empty;
            # an empty logoSvg makes shields.io reject the badge.
            if [ -n "$LOGO_FILE" ] && [ -s "$LOGO_FILE" ]; then
              jq -n --arg l "$LABEL" --arg v "$VALUE" --arg c "$COLOR" \
                --arg logo "$(cat "$LOGO_FILE")" \
                '{schemaVersion:1, label:$l, message:"\($v)%", color:$c, logoSvg:$logo, style:"flat"}' \
                > "$DIR/$NAME.json"
            else
              jq -n --arg l "$LABEL" --arg v "$VALUE" --arg c "$COLOR" \
                '{schemaVersion:1, label:$l, message:"\($v)%", color:$c, style:"flat"}' \
                > "$DIR/$NAME.json"
            fi
          }
          HELPERS

          # Pre-fetch the AXM logo once (valid URL; one logo for both badges)
          curl -fsSL https://raw.githubusercontent.com/axm-protocols/axm-forge/main/assets/logo.svg \
            > /tmp/axm-logo.svg || true

      # ── Tests with coverage ────────────────────────────────────────
      - name: Run tests with coverage
        id: coverage
        run: |
          source /tmp/badge-helpers.sh
          mkdir -p _publish/badges

          uv run pytest --cov --cov-report=json:coverage.json --no-cov-on-fail -q || true

          COV=$(jq '.totals.percent_covered_display' coverage.json | tr -d '"')
          echo "coverage=$COV" >> "$GITHUB_OUTPUT"
          write_badge "_publish/badges" "coverage" "coverage" "$COV"
          echo "📊 Coverage: ${COV}%"

      # ── AXM Audit ─────────────────────────────────────────────────
      - name: Run AXM Audit
        id: audit
        run: |
          source /tmp/badge-helpers.sh
          RESULT=$(uvx axm-audit audit . --json) || true
          SCORE=$(echo "$RESULT" | jq '.score')
          echo "score=$SCORE" >> "$GITHUB_OUTPUT"
          write_badge "_publish/badges" "axm-audit" "axm-audit" "$SCORE" /tmp/axm-logo.svg
          echo "📋 AXM Audit: $SCORE/100"

      # ── AXM Init ──────────────────────────────────────────────────
      - name: Run AXM Init Check
        id: check
        run: |
          source /tmp/badge-helpers.sh
          RESULT=$(uvx axm-init check . --json) || true
          SCORE=$(echo "$RESULT" | jq '.score')
          echo "score=$SCORE" >> "$GITHUB_OUTPUT"
          write_badge "_publish/badges" "axm-init" "axm-init" "$SCORE" /tmp/axm-logo.svg
          echo "📋 AXM Init: $SCORE/100"

      # ── Push badges ────────────────────────────────────────────────
      - name: Push badges to gh-pages
        uses: peaceiris/actions-gh-pages@v4
        with:
          github_token: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
          publish_branch: gh-pages
          publish_dir: ./_publish
          keep_files: true
          commit_message: "ci: audit={% raw %}${{ steps.audit.outputs.score }}{% endraw %} init={% raw %}${{ steps.check.outputs.score }}{% endraw %} cov={% raw %}${{ steps.coverage.outputs.coverage }}{% endraw %}%"
