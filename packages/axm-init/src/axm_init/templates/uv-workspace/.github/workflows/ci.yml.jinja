name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  test:
    runs-on: ubuntu-latest
    strategy:
      matrix:
        python-version: {{ python_matrix }}
        # PLACEHOLDER: replace `placeholder` with your real package names
        # (one entry per publishable member under packages/), e.g.
        #   package: [my-core, my-cli]
        package:
          - placeholder  # placeholder: fill in your packages/* member names
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v4
      - name: Set up Python {% raw %}${{ matrix.python-version }}{% endraw %}
        run: uv python install {% raw %}${{ matrix.python-version }}{% endraw %}
      - name: Install dependencies
        run: uv sync
      - name: Test {% raw %}${{ matrix.package }}{% endraw %}
        # `--package` is a `uv run` flag (selects the workspace member); it must
        # come before `pytest`, not be passed to pytest.
        run: uv run --package {% raw %}${{ matrix.package }}{% endraw %} pytest -q --cov

  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v4
      - run: uv sync
      - name: Ruff check
        run: uv run ruff check packages/
      - name: Ruff format
        run: uv run ruff format --check packages/

  security:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v4
      - run: uv sync
      - name: pip-audit
        run: uv run pip-audit

  coverage:
    runs-on: ubuntu-latest
    needs: test
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v4
      - run: uv sync
      - name: Run coverage
        run: uv run pytest packages/ --cov --cov-report=xml
      - uses: codecov/codecov-action@v4
        with:
          file: coverage.xml
