[project]
name = "{{ workspace_name }}"
dynamic = ["version"]
description = "{{ description }}"
readme = "README.md"
requires-python = ">={{ python_min_version }}"
license = { text = "{{ license }}" }
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]

[build-system]
requires = ["hatchling", "hatch-vcs"]
build-backend = "hatchling.build"

# The workspace root carries no shippable package of its own; hatch-vcs is
# wired only so the root version is git-tag driven (no static version to bump),
# consistent with what the gold-standard checks expect at workspace root.
[tool.hatch.version]
source = "vcs"

[tool.hatch.build.targets.wheel]
bypass-selection = true

[dependency-groups]
dev = [
    "prek>=0.4.4",
    "ruff==0.15.21",
    "pytest>=9.0.3",
    "pytest-cov>=4.0",
    "pytest-mock>=3.0",
    "mypy>=1.0",
    "pip-audit>=2.0",
]
docs = [
    "mkdocs-material>=9.0",
    "mkdocs-monorepo-plugin>=1.1",
    "mkdocstrings[python]>=1.0.3",
    "mkdocs-gen-files>=0.5",
    "mkdocs-literate-nav>=0.6.3",
]

[tool.uv.workspace]
members = ["packages/*"]

[tool.ruff]
target-version = "py{{ python_min_version | replace('.', '') }}"
line-length = 99

[tool.ruff.lint]
select = ["E", "F", "I", "N", "UP", "B", "BLE", "C4", "C901", "PLR", "S", "T20", "RUF"]
per-file-ignores = { "tests/**" = ["S101"] }

[tool.ruff.lint.mccabe]
max-complexity = 10

[tool.ruff.lint.pylint]
max-args = 5
max-branches = 12
max-returns = 6
max-statements = 50
max-locals = 15

[tool.pytest.ini_options]
testpaths = ["packages/*/tests"]
import_mode = "importlib"
addopts = "-q --import-mode=importlib"

# The workspace root ships no package of its own, so it has no docs/*.md to
# bundle into a wheel. Opt out of the wheel-doc shipping check explicitly
# (docs live under each member package + the shared mkdocs site).
[tool.axm-init.wheel-doc]
files = []

[tool.coverage.run]
source_pkgs = []

[tool.coverage.report]
show_missing = true
fail_under = 80

# mypy is configured per-package under packages/*/pyproject.toml.
# No root [tool.mypy] block — keeps `audit type` (per-package) and
# `make typecheck` consistent. See mypy-consistency skill.

# ─────────────────────────────────────────────────────────────────────────────
# Git-Cliff Changelog Configuration
# ─────────────────────────────────────────────────────────────────────────────
[tool.git-cliff.changelog]
header = """
# Changelog

All notable changes to this project will be documented in this file.
"""
body = """
{% raw %}{% if version %}\
    ## [{{ version | trim_start_matches(pat="v") }}] - {{ timestamp | date(format="%Y-%m-%d") }}
{% else %}\
    ## [Unreleased]
{% endif %}\
{% for group, commits in commits | group_by(attribute="group") %}
    ### {{ group | striptags | trim | upper_first }}
    {% for commit in commits %}
        - {{ commit.message | upper_first }}\
    {% endfor %}
{% endfor %}
{% endraw %}"""
trim = true

[tool.git-cliff.git]
conventional_commits = true
filter_unconventional = true
commit_parsers = [
    { message = "^chore", skip = true },
    { message = "^ci", skip = true },
    { message = "^feat", group = "🚀 Features" },
    { message = "^fix", group = "🐛 Bug Fixes" },
    { message = "^doc", group = "📚 Documentation" },
    { message = "^perf", group = "⚡ Performance" },
    { message = "^refactor", group = "🔧 Refactor" },
    { message = "^test", group = "🧪 Tests" },
]
tag_pattern = "v[0-9].*"
