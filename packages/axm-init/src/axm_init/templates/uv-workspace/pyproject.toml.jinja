[project]
name = "{{ workspace_name }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
requires-python = ">={{ python_min_version }}"
license = { text = "{{ license }}" }
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]

[dependency-groups]
dev = [
    "pre-commit>=4.0",
    "ruff==0.15.12",
    "pytest>=9.0.3",
    "pytest-cov>=4.0",
    "pytest-mock>=3.0",
    "mypy>=1.0",
]

[tool.uv.workspace]
members = ["packages/*"]

[tool.ruff]
target-version = "py{{ python_min_version | replace('.', '') }}"
line-length = 99

[tool.ruff.lint]
select = ["E", "F", "I", "N", "UP", "B", "C4", "C901", "S", "T20", "RUF"]
per-file-ignores = { "tests/**" = ["S101"] }

[tool.ruff.lint.mccabe]
max-complexity = 10

[tool.ruff.lint.pylint]
max-args = 5
max-branches = 12
max-returns = 6
max-statements = 50
max-locals = 15

[tool.pytest.ini_options]
testpaths = ["packages"]
addopts = "-q --import-mode=importlib"

[tool.coverage.run]
source_pkgs = []

[tool.coverage.report]
show_missing = true
fail_under = 80

[tool.mypy]
python_version = "{{ python_min_version }}"
strict = true
warn_unused_configs = true
